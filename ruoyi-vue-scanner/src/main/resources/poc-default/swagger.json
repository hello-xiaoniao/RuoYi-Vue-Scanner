{
  "comment": "RuoYi Swagger/API文档泄露检测. 路径检测时自动补全 baseApi 前缀试探",
  "paths": [
    "/swagger-resources",
    "/swagger-ui.html",
    "/swagger-ui/index.html",
    "/doc.html",
    "/v2/api-docs",
    "/v3/api-docs",
    "/v3/api-docs/swagger-config",
    "/swagger-ui/swagger-initializer.js",
    "/swagger-ui/oauth2-redirect.html",
    "/webjars/springfox-swagger-ui/springfox.css",
    "/webjars/springfox-swagger-ui/swagger-ui-bundle.js",
    "/webjars/springfox-swagger-ui/swagger-ui-standalone-preserve.js",
    "/swagger-resources/configuration/ui",
    "/swagger-resources/configuration/security",
    "/swagger-ui/favicon-32x32.png",
    "/v2/api-docs-ext"
  ],
  "features": [
    "swaggerversion",
    "swaggeruibundle",
    "swagger-ui",
    "swagger-resources",
    "\"swagger\":",
    "\"openapi\":",
    "Swagger2",
    "springfox",
    "api-docs",
    "knife4j",
    "swagger2",
    "\"info\":{\"description\":\""
  ],
  "deny_patterns": [
    "\"code\":401",
    "\"code\":403",
    "\"code\":404",
    "认证失败",
    "未登录",
    "无法访问系统资源",
    "access denied",
    "unauthorized",
    "没有权限",
    "服务内部错误",
    "Not Found",
    "404 Not Found"
  ]
}